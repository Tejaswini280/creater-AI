# =========================
# Docker Environment Configuration
# =========================
NODE_ENV=development
PORT=5000

# =========================
# Database Configuration (Docker)
# =========================
DB_NAME=creators_dev_db
DB_USER=postgres
DB_PASSWORD=postgres123
DB_HOST=postgres
DB_PORT=5432

# Database URL for Docker
DATABASE_URL=postgresql://postgres:postgres123@postgres:5432/creators_dev_db

# =========================
# Redis Configuration
# =========================
REDIS_URL=redis://redis:6379

# =========================
# AI API Keys (Set these with your actual keys)
# =========================
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# =========================
# Kling AI API Keys
# =========================
KLING_ACCESS_KEY=your_kling_access_key_here
KLING_SECRET_KEY=your_kling_secret_key_here

# =========================
# hCaptcha Keys
# =========================
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# =========================
# Session & Auth (Docker)
# =========================
SESSION_SECRET=CreatorNexus-Dev-Secret-2024-Docker
JWT_SECRET=CreatorNexus-JWT-Secret-2024-Docker
JWT_REFRESH_SECRET=CreatorNexus-Refresh-Secret-2024-Docker

# =========================
# Dev Settings
# =========================
SKIP_RATE_LIMIT=1
PERF_MODE=1